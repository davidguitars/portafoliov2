---
import { author } from "../sample";
---

<footer
  style="border-top: 1px solid var(--border); background: var(--bg-dark);">
  <div
    style="max-width: var(--max-w); margin: 0 auto; padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <a
      href="/"
      style="font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600; color: #F5F4F0; display: flex; align-items: center; gap: 0.5rem;">
      <span
        style="display: inline-block; width: 6px; height: 6px; background: var(--accent);"
      ></span>
      {author.nickname}
    </a>

    <p
      style="font-family: var(--font-mono); font-size: 0.65rem; color: #3A3A38; max-width: none;">
      © {new Date().getFullYear()}
      {author.nickname} · Todos los derechos reservados
    </p>

    <div style="display: flex; gap: 2.25rem;">
      {
        [{ icon: "ri-linkedin-box-fill", link: author.linkedin }].map((s) => (
          <a
            href={s.link}
            target="_blank"
            style="color: #3A3A38; transition: color 0.15s ease; font-size: 1rem;"
            class="footer-social">
            <i class={s.icon} />
          </a>
        ))
      }
    </div>
  </div>
</footer>

<style>
  .footer-social:hover {
    color: var(--accent) !important;
  }
</style>
