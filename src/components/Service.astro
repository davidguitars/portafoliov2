---
const stats = [
  { val: "50+", label: "Proyectos" },
  { val: "120%", label: "ROI promedio" },
  { val: "7+", label: "Años exp." },
  { val: "6", label: "Certs. IA" },
];

const services = [
  {
    num: "01",
    name: "Diseño UX/UI",
    desc: "Investigación de usuarios, wireframes, prototipos y sistemas de diseño que eliminan fricción y aumentan conversión.",
  },
  {
    num: "02",
    name: "Desarrollo Frontend",
    desc: "Implementación en Astro, React y Webflow. Código limpio, rendimiento optimizado y animaciones que enamoran.",
  },
  {
    num: "03",
    name: "Automatización con IA",
    desc: "Flujos inteligentes con N8N y herramientas de IA que reducen trabajo manual y escalan tu operación.",
  },
  {
    num: "04",
    name: "Estrategia Digital",
    desc: "Marketing con IA, análisis de métricas y posicionamiento de marca para atraer clientes de mayor valor.",
  },
];
---

<section id="servicios" style="border-bottom: 1px solid var(--border);">
  <div style="max-width: var(--max-w); margin: 0 auto;">
    <!-- Header de sección -->
    <div
      style="display: grid; grid-template-columns: 1fr 2fr; border-bottom: 1px solid var(--border);"
      class="service-header">
      <div
        style="padding: 2.5rem 1.5rem; border-right: 1px solid var(--border);">
        <div class="label-tag" style="margin-bottom: 0.75rem;">Servicios</div>
        <div
          style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--ink-faint);">
          [02]
        </div>
      </div>
      <div style="padding: 2.5rem 2rem; display: flex; align-items: flex-end;">
        <h2
          style="font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 500; color: var(--ink); max-width: 22ch;">
          Lo que construyo para clientes que quieren resultados reales
        </h2>
      </div>
    </div>

    <!-- Grid de stats -->
    <div
      style="display: grid; grid-template-columns: repeat(4, 1fr); border-bottom: 1px solid var(--border);"
      class="stats-grid">
      {
        stats.map((s, i) => (
          <div
            style={`padding: 1.5rem; ${i < stats.length - 1 ? "border-right: 1px solid var(--border);" : ""}`}>
            <div style="font-family: var(--font-mono); font-size: 1.8rem; font-weight: 600; color: var(--ink);">
              {s.val}
            </div>
            <div class="label-tag" style="margin-top: 0.3rem;">
              {s.label}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Grid de servicios -->
    <div
      style="display: grid; grid-template-columns: 1fr 1fr;"
      class="services-grid">
      {
        services.map((s, i) => (
          <div
            style={`
          padding: 2rem 2rem 2rem 1.5rem;
          ${i % 2 === 0 ? "border-right: 1px solid var(--border);" : ""}
          ${i < 2 ? "border-bottom: 1px solid var(--border);" : ""}
          transition: background 0.15s ease;
          cursor: default;
        `}
            class="service-item">
            <div style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--ink-faint); margin-bottom: 1rem;">
              [{s.num}]
            </div>
            <h3 style="font-family: var(--font-mono); font-size: 1rem; font-weight: 500; color: var(--ink); margin-bottom: 0.75rem;">
              {s.name}
            </h3>
            <p style="font-size: 0.88rem; line-height: 1.65; color: var(--ink-muted); max-width: 32ch;">
              {s.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-item:hover {
    background: var(--bg-surface);
  }

  @media (max-width: 768px) {
    .service-header,
    .services-grid {
      grid-template-columns: 1fr !important;
    }
    .service-header > div:first-child {
      border-right: none !important;
      border-bottom: 1px solid var(--border);
    }
    .stats-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    .stats-grid > div:nth-child(2) {
      border-right: none !important;
    }
  }
</style>
