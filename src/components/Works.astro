---
const portfolio = [
  {
    num: "01",
    name: "Estudio Roca",
    tags: "UX Research · UI Design · Webflow",
    cover: `/images/estudioroca desktop.png`,
    link: "https://estudioroca.cl/",
    year: "2024",
  },
  {
    num: "02",
    name: "Vetercalm",
    tags: "UI Design · Desarrollo · WordPress",
    cover: `/images/vetercalm.jpeg`,
    link: "https://vetercalm.cl/",
    year: "2025",
  },
  {
    num: "03",
    name: "Decorafácil",
    tags: "UI Design · Shopify · E-commerce",
    cover: `/images/decorafacil.jpeg`,
    link: "https://decorafacil.cl/",
    year: "2026",
    external: true,
  },
  {
    num: "04",
    name: "Lira Project",
    tags: "UX Research · WordPress · Branding",
    cover: `/images/liraproject.jpeg`,
    link: "https://liraproject.cl/",
    year: "2025",
    external: true,
  },
];
---

<section id="work" style="border-bottom: 1px solid var(--border);">
  <div style="max-width: var(--max-w); margin: 0 auto;">

    <!-- Header de sección -->
    <div style="display: flex; align-items: center; gap: 1rem; padding: 2.5rem 1.5rem; border-bottom: 1px solid var(--border); justify-content: space-between;">
      <div style="display: flex; align-items: center; gap: 1rem;">
        <div style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--ink-faint);">[03]</div>
        <h2 style="font-size: 1.1rem; font-weight: 500; font-family: var(--font-mono); color: var(--ink);">Trabajo seleccionado</h2>
      </div>
      <div class="label-tag">{portfolio.length} proyectos</div>
    </div>

    <!-- Grid de proyectos -->
    <div style="display: grid; grid-template-columns: 1fr 1fr;" class="works-grid">
      {portfolio.map((item, i) => (
        <a
          href={item.link}
          target={item.external ? "_blank" : "_self"}
          rel={item.external ? "noopener noreferrer" : undefined}
          style={`
            display: block;
            padding: 1.75rem 1.5rem;
            ${i % 2 === 0 ? 'border-right: 1px solid var(--border);' : ''}
            ${i < 2 ? 'border-bottom: 1px solid var(--border);' : ''}
            transition: background 0.15s ease;
          `}
          class="work-card"
        >
          <!-- Imagen -->
          <div style="width: 100%; aspect-ratio: 16/9; overflow: hidden; border: 1px solid var(--border); margin-bottom: 1.25rem; background: var(--bg-surface);">
            <img
              src={item.cover}
              alt={item.name}
              style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; display: block;"
              class="work-img"
            />
          </div>

          <!-- Info -->
          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;">
            <div>
              <div style="font-family: var(--font-mono); font-size: 0.6rem; color: var(--ink-faint); margin-bottom: 0.35rem;">[{item.num}] · {item.year}</div>
              <h3 style="font-family: var(--font-mono); font-size: 1rem; font-weight: 500; color: var(--ink); margin-bottom: 0.3rem;">{item.name}</h3>
              <p style="font-size: 0.78rem; color: var(--ink-faint); font-family: var(--font-mono);">{item.tags}</p>
            </div>
            <div style="width: 28px; height: 28px; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1rem; font-family: var(--font-mono); font-size: 0.9rem; color: var(--ink-muted); transition: background 0.15s ease, color 0.15s ease;" class="work-arrow">
              {item.external ? '↗' : '→'}
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .work-card:hover { background: var(--bg-surface); }
  .work-card:hover .work-img { transform: scale(1.03); }
  .work-card:hover .work-arrow { background: var(--ink); color: var(--accent); border-color: var(--ink); }

  @media (max-width: 768px) {
    .works-grid { grid-template-columns: 1fr !important; }
    .works-grid a { border-right: none !important; }
  }
</style>
