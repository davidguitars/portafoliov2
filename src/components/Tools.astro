---
const mytools = [
  "Figma", "React", "Astro", "Webflow", "N8N",
  "Notion", "Node.js", "Wordpress", "Shopify",
  "Tailwind", "Jira", "Framer",
];
---

<script>
  import { gsap } from "gsap";
  document.addEventListener("DOMContentLoaded", () => {
    const track = document.querySelector("#ticker-track") as HTMLElement;
    if (!track) return;
    Array.from(track.children).forEach((el) => {
      track.appendChild(el.cloneNode(true));
    });
    gsap.to(track, {
      x: -(track.scrollWidth / 2),
      duration: 35,
      ease: "none",
      repeat: -1,
    });
  });
</script>

<div style="border-bottom: 1px solid var(--border); border-top: 1px solid var(--border); overflow: hidden; background: var(--bg-dark); padding: 0.9rem 0;">
  <div id="ticker-track" style="display: flex; align-items: center; gap: 0; width: max-content;">
    {mytools.map((tool) => (
      <div style="display: flex; align-items: center; gap: 0; white-space: nowrap;">
        <span style="font-family: var(--font-mono); font-size: 0.72rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: #F5F4F0; padding: 0 1.8rem;">
          {tool}
        </span>
        <span style="color: #3A3A38; font-size: 0.9rem; user-select: none;">/</span>
      </div>
    ))}
  </div>
</div>
