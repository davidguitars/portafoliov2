---
import '../styles/global.css'
import Layout from "../layouts/Layout.astro";
import AppHeader from '../components/Header.astro';
import AppFooter from '../components/Footer.astro';

const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true }));
allPosts.sort((a: any, b: any) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
---

<Layout title="Blog — David Urdaneta">
  <AppHeader />

  <main>
    <!-- Header de sección -->
    <div style="border-bottom: 1px solid var(--border);">
      <div style="max-width: var(--max-w); margin: 0 auto; padding: 4rem 1.5rem 3rem; display: grid; grid-template-columns: 1fr 2fr; gap: 2rem;" class="blog-header-grid">
        <div>
          <div style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--ink-faint); margin-bottom: 0.75rem;">[Blog]</div>
          <div class="label-tag">{allPosts.length} artículos</div>
        </div>
        <div>
          <h1 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 500; color: var(--ink); letter-spacing: -0.03em; margin-bottom: 0.75rem;">
            Notas sobre diseño,<br/>desarrollo e IA.
          </h1>
          <p style="font-size: 0.9rem; color: var(--ink-muted); max-width: 44ch;">
            Recursos prácticos para equipos que quieren construir mejores productos digitales.
          </p>
        </div>
      </div>
    </div>

    <!-- Lista de posts -->
    <div style="max-width: var(--max-w); margin: 0 auto;">
      {(allPosts as any[]).map(({ url, frontmatter }: any, i: number) => (
        <a
          href={url}
          style={`
            display: grid;
            grid-template-columns: 200px 1fr;
            gap: 0;
            border-bottom: 1px solid var(--border);
            transition: background 0.15s ease;
            text-decoration: none;
            color: inherit;
          `}
          class="post-row"
        >
          <!-- Imagen -->
          <div style="border-right: 1px solid var(--border); overflow: hidden; aspect-ratio: 16/10; background: var(--bg-surface);">
            <img
              src={frontmatter?.image?.url}
              alt={frontmatter.title}
              style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; display: block;"
              class="post-img"
            />
          </div>

          <!-- Contenido -->
          <div style="padding: 1.75rem 2rem; display: flex; flex-direction: column; justify-content: space-between; gap: 0.75rem;">
            <div>
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                {frontmatter.tags?.filter(Boolean).map((tag: string) => (
                  <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-faint); border: 1px solid var(--border); padding: 0.15rem 0.5rem;">{tag}</span>
                ))}
              </div>
              <h2 style="font-family: var(--font-mono); font-size: 1.05rem; font-weight: 500; color: var(--ink); line-height: 1.3; margin-bottom: 0.5rem;">{frontmatter.title}</h2>
            </div>
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <span style="font-family: var(--font-mono); font-size: 0.68rem; color: var(--ink-faint);">{frontmatter.pubDate}</span>
              <span style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--ink-muted); transition: color 0.15s;" class="post-arrow">→ Leer</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>

  <AppFooter />
</Layout>

<style>
  .post-row:hover { background: var(--bg-surface); }
  .post-row:hover .post-img { transform: scale(1.04); }
  .post-row:hover .post-arrow { color: var(--ink); }

  @media (max-width: 640px) {
    .blog-header-grid { grid-template-columns: 1fr !important; }
    .post-row { grid-template-columns: 1fr !important; }
    .post-row > div:first-child { border-right: none !important; border-bottom: 1px solid var(--border); aspect-ratio: 16/7 !important; }
  }
</style>